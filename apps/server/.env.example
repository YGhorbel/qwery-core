
# Storage
QWERY_STORAGE_DIR=qwery.db

# Extensions discovery
QWERY_EXTENSIONS_PATH=

# Azure OpenAI — used for artifact generation (labeling, classification)
AZURE_API_KEY=
AZURE_RESOURCE_NAME=
AZURE_OPENAI_DEPLOYMENT=gpt-5.2

# Anthropic
ANTHROPIC_API_KEY=

# Ollama Cloud — get API key from ollama.com/settings
AGENT_PROVIDER=ollama-cloud
OLLAMA_API_KEY=
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_BASE_URL=https://ollama.com/v1

# Telemetry
QWERY_TELEMETRY_ENABLED=false
QWERY_TELEMETRY_DEBUG=false

# Default model
DEFAULT_MODEL=ollama-cloud/deepseek-v4-flash:cloud

# Schema cache
QWERY_SCHEMA_CACHE=true
QWERY_SCHEMA_CACHE_TTL_HOURS=24

# Task-specific models (Ollama Cloud)
# SQL generation and template adaptation
OLLAMA_SQL_MODEL=qwen3-coder-next:cloud
# Reasoning, correction, judging — thinking mode, 1M context
OLLAMA_REASONING_MODEL=deepseek-v4-flash:cloud
# Pipeline agents 05 & 07 (business rules, concept classifier)
OLLAMA_PIPELINE_MODEL=deepseek-v4-flash:cloud
# Lightweight tasks: narration, labeling fallback (when Azure not configured)
OLLAMA_REASONING_SMALL=nemotron-3-nano:30b-cloud

# Internal Postgres for pgvector term index
QWERY_INTERNAL_DATABASE_URL=

# Local Ollama embeddings — run: ollama pull qwen3-embedding:8b && ollama serve
OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:8b
QWERY_EMBEDDING_DIMENSIONS=4096

# Semantic pipeline execution mode
QWERY_PIPELINE_MODE=background

# Cosine similarity threshold for semantic context
QWERY_SEMANTIC_THRESHOLD=0.7
