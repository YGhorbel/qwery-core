    "@qwery/extensions-sdk": "workspace:*",
    "@qwery/shared": "workspace:*",
    "ai": "catalog:",
    "nats": "^2.20.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "semver": "^7.7.1",
    "yaml": "^2.8.1",
    "zod": "catalog:"
